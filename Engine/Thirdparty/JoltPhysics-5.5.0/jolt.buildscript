[project:JoltPhysics]
type = lib
outdir = ../../../bin/
sources = Jolt/**/*.cpp
headers = Jolt/**/*.h Jolt/**/*.inl
includes = .
public_includes = .
defines = JPH_OBJECT_STREAM
if(Windows)
{
    defines = JPH_OBJECT_STREAM, JPH_USE_AVX2
}
if(Linux)
{
    defines = JPH_OBJECT_STREAM, JPH_USE_AVX2
    cxxflags = -pthread
    ldflags = -pthread
}
std = 17
multiprocessor = true
simd = AdvancedVectorExtensions2
