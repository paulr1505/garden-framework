find_package(Vulkan REQUIRED)
if(Linux)
{
    find_package(SDL3 REQUIRED)
}
if(macOS)
{
    find_package(SDL3 REQUIRED)
}
if(Windows)
{
    find_package(DirectX12 REQUIRED)
}

[project:EngineGraphics]
type = dll
outdir = ../bin/
sources = {
    src/Graphics/RenderAPI.cpp
    src/Graphics/Vulkan/VulkanRenderAPI.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Device.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Swapchain.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Pipeline.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Descriptors.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Frame.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Rendering.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Commands.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Shadow.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Skybox.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_FXAA.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_SSAO.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_Viewport.cpp
    src/Graphics/Vulkan/VulkanPostProcessPass.cpp
    src/Graphics/Vulkan/VulkanRGBackend.cpp
    src/Graphics/Vulkan/VulkanPostProcessGraphBuilder.cpp
    src/Graphics/Vulkan/VulkanGBufferPass.cpp
    src/Graphics/Vulkan/VulkanRenderAPI_GBuffer.cpp
    src/Graphics/Vulkan/VulkanMesh.cpp
    src/Graphics/Vulkan/VulkanSceneViewport.cpp
    src/Graphics/Vulkan/VulkanDeferredLightingPass.cpp
    src/Graphics/D3D12/D3D12RenderAPI.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Device.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Swapchain.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Pipeline.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Frame.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Rendering.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Shadow.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Skybox.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_FXAA.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_SSAO.cpp [windows]
    src/Graphics/D3D12/D3D12RenderAPI_Viewport.cpp [windows]
    src/Graphics/D3D12/D3D12Mesh.cpp [windows]
    src/Graphics/D3D12/D3D12CopyQueue.cpp [windows]
    src/Graphics/D3D12/D3D12PSOCache.cpp [windows]
    src/Graphics/D3D12/D3D12ResourceStateTracker.cpp [windows]
    src/Graphics/D3D12/D3D12PostProcessPass.cpp [windows]
    src/Graphics/D3D12/D3D12RGBackend.cpp [windows]
    src/Graphics/D3D12/D3D12PostProcessGraphBuilder.cpp [windows]
    src/Graphics/D3D12/D3D12GBufferPass.cpp [windows]
    src/Graphics/D3D12/D3D12SceneViewport.cpp [windows]
    src/Graphics/RenderGraph/RenderGraph.cpp
    src/Graphics/RenderGraph/RGCompiler.cpp
    src/Graphics/RenderGraph/RGBuilder.cpp
    src/Graphics/RenderGraph/PostProcessGraphBuilder.cpp
    src/Graphics/Metal/MetalRenderAPI.mm [macOS]
    src/Graphics/Metal/MetalRenderAPI_Frame.mm [macOS]
    src/Graphics/Metal/MetalRenderAPI_Rendering.mm [macOS]
    src/Graphics/Metal/MetalRenderAPI_Shadow.mm [macOS]
    src/Graphics/Metal/MetalRenderAPI_Viewport.mm [macOS]
    src/Graphics/Metal/MetalRenderAPI_SSAO.mm [macOS]
    src/Graphics/Metal/MetalMesh.mm [macOS]
    src/Graphics/Metal/MetalRenderAPI_Commands.mm [macOS]
    src/Graphics/Metal/MetalSceneViewport.mm [macOS]
    src/Graphics/stb_impl.cpp
    src/ImGui/ImGuiManager.cpp
    src/UI/RmlUiManager.cpp
    src/UI/RmlRenderer_VK.cpp
    src/UI/RmlRenderer_D3D12.cpp [windows]
    src/UI/RmlRenderer_Metal.mm [macOS]
    src/Reflection/ReflectionWidgets.cpp
    Thirdparty/ImGuizmo/ImGuizmo.cpp
}
headers = {
    src/Graphics/**/*.hpp
    src/Graphics/**/*.h
    src/ImGui/**/*.hpp
    src/UI/**/*.h
}
defines = RMLUI_SDL_VERSION_MAJOR=3, ENGINEGRAPHICS_BUILDING_DLL, RMLUI_CORE_EXPORTS, RMLUI_DEBUGGER_EXPORTS, USE_IMGUI_API
if(Windows)
{
    includes = ${Vulkan_INCLUDE_DIRS}, ${DirectX12_INCLUDE_DIRS}
    libs = ${Vulkan_LIBRARIES}, ${DirectX12_LIBRARIES}
    libdirs = ${Vulkan_LIBRARY_DIRS}, ${DirectX12_LIBRARY_DIRS}
}
if(Linux)
{
    includes = ${Vulkan_INCLUDE_DIRS}
    libs = ${Vulkan_LIBRARIES}
    libdirs = ${Vulkan_LIBRARY_DIRS}
}
if(macOS)
{
    includes = ${Vulkan_INCLUDE_DIRS}
    libs = ${Vulkan_LIBRARIES}, -framework Metal, -framework QuartzCore, -framework Cocoa
    libdirs = ${Vulkan_LIBRARY_DIRS}
    objcflags = -fobjc-arc
    ldflags = -Xlinker -install_name -Xlinker @loader_path/EngineGraphics.dylib
}
target_link_libraries(
    PUBLIC EngineCore
    PUBLIC vk-bootstrap
    PUBLIC VMA
    PUBLIC WHOLE_ARCHIVE imgui-docking
    PUBLIC imguizmo
    PUBLIC RmlUi
)
multiprocessor = true
simd = AdvancedVectorExtensions2
std = 20
utf8 = true
exception_handling = false
buffer_security_check = false
